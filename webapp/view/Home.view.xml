<mvc:View
    controllerName="com.zeim.fatturazioneattiva.controller.Home"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:t="sap.ui.table"
    xmlns:card="sap.f.cards"
    xmlns:form="sap.ui.layout.form"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:vh="sap.ui.comp.valuehelpdialog"
>
    <Page showHeader="false">
        <Panel visible="{appModel>/ui/showSegmented}">
            <FlexBox
                alignItems="Start"
                justifyContent="Center"
            >
                <SegmentedButton
                    id="idSegmentedBtn"
                    selectionChange=".onSegmentedButtonSelectionChange"
                    selectedKey="sd"
                    visible="{appModel>/ui/showSegmented}"
                >
                    <items>
                        <SegmentedButtonItem
                            key="sd"
                            text="Flusso Fatture SD"
                            width="auto"
                        />
                        <SegmentedButtonItem
                            key="fi"
                            text="Flusso Fatture FI"
                            width="auto"
                        />
                    </items>
                </SegmentedButton>
            </FlexBox>
        </Panel>

        <Panel headerText="Filtri di ricerca">
            <fb:FilterBar
                id="filterBar"
                persistencyKey="myPersKey"
                useToolbar="false"
                search=".onFilterBarSearch"
                showGoOnFB="true"
                isRunningInValueHelpDialog="false"
            >
                <fb:filterGroupItems>
                    <fb:FilterGroupItem
                        name="Customer"
                        label="Cliente"
                        groupName="Cliente"
                        visibleInFilterBar="true"
                    >
                        <fb:control>
                            <MultiInput
                                id="multiInput"
                                width="300px"
                                showValueHelp="true"
                                valueHelpRequest=".onValueHelpClienti"
                                showSuggestion="true"
                                suggestionItems="{path: 'Clienti>/I_Customer'}"
                                data-model="Clienti"
                                data-key="Customer"
                                data-desc="OrganizationBPName1"
                            >
                                <suggestionItems>
                                    <core:Item
                                        key="{Clienti>Customer}"
                                        text="{Clienti>OrganizationBPName1}"
                                    />
                                </suggestionItems>
                            </MultiInput>
                        </fb:control>
                    </fb:FilterGroupItem>
                    <fb:FilterGroupItem
                        name="document"
                        label="Nr. Documento"
                        groupName="NrDocumento"
                        visibleInFilterBar="true"
                    >
                        <fb:control>
                            <Input
                                id="inputDocumento"
                                width="300px"
                                type="Number"
                            />
                        </fb:control>
                    </fb:FilterGroupItem>
                    <fb:FilterGroupItem
                        name="Paese dell'Esec.Pag."
                        label="Paese dell'Esec.Pag."
                        groupName="General"
                        visibleInFilterBar="true"
                    >
                        <fb:control>
                            <MultiInput
                                id="multiInputPaeseEsecutore"
                                width="300px"
                                showValueHelp="true"
                                valueHelpRequest=".onValueHelpPaeseEsecutore"
                                showSuggestion="true"
                                suggestionItems="{path: 'MCPaeseEsecutore>/I_Country'}"
                                data-model="MCPaeseEsecutore"
                                data-key="Country"
                                data-desc="Country_Text"
                            >
                                <suggestionItems>
                                    <core:Item
                                        key="{MCPaeseEsecutore>Country}"
                                        text="{MCPaeseEsecutore>Country_Text}"
                                    />
                                </suggestionItems>
                            </MultiInput>
                        </fb:control>
                    </fb:FilterGroupItem>
                    <fb:FilterGroupItem
                        name="Org. Commerciale"
                        label="Org. Commerciale"
                        groupName="General"
                        visibleInFilterBar="true"
                    >
                        <fb:control>
                            <Select
                                id="selectOrgCommerciale"
                                width="300px"
                                forceSelection="false"
                                items="{
                                    path: 'MCOrgCommerciale>/ZR_EIM_SALESORGANIZATION'}"
                            >
                                <core:Item
                                    key="{MCOrgCommerciale>SalesOrganization}"
                                    text="{MCOrgCommerciale>SalesOrganization}"
                                />
                            </Select>
                        </fb:control>
                    </fb:FilterGroupItem>
                    <fb:FilterGroupItem
                        name="Data"
                        label="Data Registrazione"
                        groupName="General"
                        visibleInFilterBar="true"
                    >
                        <fb:control>
                            <DateRangeSelection
                                id="dateRangePicker"
                                delimiter=" - "
                                width="300px"
                                displayFormat="dd/MM/yyyy"
                                valueFormat="yyyy-MM-dd"
                            />
                        </fb:control>
                    </fb:FilterGroupItem>

                    <fb:FilterGroupItem
                        name="Società"
                        label="Società"
                        groupName="General"
                        visibleInFilterBar="true"
                    >
                        <fb:control>
                            <Select
                                id="selectSocieta"
                                width="300px"
                                forceSelection="false"
                                items="{
                                    path: 'MCSocieta>/ZR_EIM_COMPANY'}"
                            >
                                <core:Item
                                    key="{MCSocieta>CompanyCode}"
                                    text="{MCSocieta>CompanyCode}"
                                />
                            </Select>
                        </fb:control>
                    </fb:FilterGroupItem>

                    <fb:FilterGroupItem
                        name="Tipo Fattura SD"
                        label="{appModel>/ui/tipoFatturaSdLabel}"
                        groupName="General"
                        visibleInFilterBar="true"
                    >
                        <fb:control>
                            <MultiInput
                                id="multiInputTipoFatturaSD"
                                width="300px"
                                showValueHelp="true"
                                valueHelpRequest=".onValueHelpTipoFatturaSD"
                                showSuggestion="true"
                                suggestionItems="{path: 'MCTipoFatturaSD>/I_BillingDocumentTypeStdVH'}"
                                data-model="MCTipoFatturaSD"
                                data-key="BillingDocumentType"
                                data-desc="BillingDocumentType_Text"
                            >
                                <suggestionItems>
                                    <core:Item
                                        key="{MCTipoFatturaSD>BillingDocumentType}"
                                        text="{MCTipoFatturaSD>BillingDocumentType}"
                                    />
                                </suggestionItems>
                            </MultiInput>
                        </fb:control>
                    </fb:FilterGroupItem>
                    <fb:FilterGroupItem
                        name="Tipo Fattura FI"
                        label="Tipo Fattura FI"
                        groupName="General"
                        visibleInFilterBar="true"
                    >
                        <fb:control>
                            <MultiInput
                                id="multiInputTipoFatturaFI"
                                width="300px"
                                showValueHelp="true"
                                valueHelpRequest=".onValueHelpTipoFatturaFI"
                                showSuggestion="true"
                                suggestionItems="{path: 'MCTipoFatturaFI>/I_AccountingDocumentType'}"
                                data-model="MCTipoFatturaFI"
                                data-key="AccountingDocumentType"
                                data-desc="AccountingDocumentType_Text"
                            >
                                <suggestionItems>
                                    <core:Item
                                        key="{MCTipoFatturaFI>AccountingDocumentType}"
                                        text="{MCTipoFatturaFI>AccountingDocumentType}"
                                    />
                                </suggestionItems>
                            </MultiInput>
                        </fb:control>
                    </fb:FilterGroupItem>
                </fb:filterGroupItems>
            </fb:FilterBar>
        </Panel>

        <IconTabBar
            id="idIconTabBar"
            select=".onIconTabSelect"
            expandable="false"
            expanded="false"
        >
            <items>
                <IconTabFilter
                    key="All"
                    text="Fatture"
                    showAll="true"
                    count="{viewModel>/counts/All}"
                    icon="sap-icon://documents"
                    iconColor="Neutral"
                />
                <IconTabSeparator />
                <IconTabFilter
                    key="Processed"
                    text="Completate"
                    icon="sap-icon://accept"
                    iconColor="Positive"
                    count="{viewModel>/counts/Processed}"
                />
                <IconTabFilter
                    key="Working"
                    text="Da processare"
                    icon="sap-icon://pending"
                    iconColor="Critical"
                    count="{viewModel>/counts/Working}"
                />
                <IconTabFilter
                    key="Error"
                    text="In errore"
                    icon="sap-icon://error"
                    iconColor="Negative"
                    count="{viewModel>/counts/Error}"
                />
            </items>
        </IconTabBar>
        <MessageStrip
            text="Le fatture selezionate sono in fase di invio all'intermediario. Si prega di aggiornare la lista tra qualche minuto per verificare lo stato di invio."
            showIcon="true"
            showCloseButton="true"
            visible="{= ${viewModel>/messageStrip/visible} }"
            class="sapUiMediumMarginBottom"
        />
        <t:Table
            id="idTableFatture"
            rows="{fattureModel>/results}"
            selectionMode="MultiToggle"
            selectionBehavior="RowSelector"
            visibleRowCountMode="Auto"
            minAutoRowCount="10"
            enableColumnReordering="true"
            enableCellFilter="true"
            rowSelectionChange=".onSelectionChange"
            class="sapUiSmallMarginTop"
        >
            <t:extension>
                <OverflowToolbar>
                    <Title text="Cruscotto fatture" />
                    <ToolbarSpacer />
                    <Button
                        icon="sap-icon://action-settings"
                        text="Layout colonne"
                        press=".onOpenColumnLayoutDialog"
                    />
                    <Button
                        icon="sap-icon://excel-attachment"
                        text="Esporta Excel"
                        press=".onExportExcel"
                    />
                </OverflowToolbar>
            </t:extension>

            <t:columns>
                <t:Column
                    id="colBukrs"
                    width="6rem"
                    sortProperty="bukrs"
                    filterProperty="bukrs"
                >
                    <Label text="Società" />
                    <t:template>
                        <Text text="{fattureModel>bukrs}" />
                    </t:template>
                </t:Column>

                <t:Column
                    id="colKunnr"
                    width="7rem"
                    sortProperty="kunnr"
                    filterProperty="kunnr"
                >
                    <Label text="Cliente" />
                    <t:template>
                        <Link
                            text="{fattureModel>kunnr}"
                            press=".onNavToCliente"
                        />
                    </t:template>
                </t:Column>

                <t:Column
                    id="colCustomerName"
                    width="12rem"
                    sortProperty="CustomerName"
                    filterProperty="CustomerName"
                >
                    <Label text="Nominativo" />
                    <t:template>
                        <Text text="{fattureModel>CustomerName}" />
                    </t:template>
                </t:Column>

                <t:Column
                    id="colStcd2"
                    width="9rem"
                    sortProperty="stcd2"
                    filterProperty="stcd2"
                >
                    <Label text="P.IVA" />
                    <t:template>
                        <Text text="{fattureModel>stcd2}" />
                    </t:template>
                </t:Column>

                <t:Column
                    id="colStcd1"
                    width="9rem"
                    sortProperty="stcd1"
                    filterProperty="stcd1"
                >
                    <Label text="C.F." />
                    <t:template>
                        <Text text="{fattureModel>stcd1}" />
                    </t:template>
                </t:Column>

                <t:Column
                    id="colVbeln"
                    width="8rem"
                    sortProperty="vbeln"
                    filterProperty="vbeln"
                >
                    <Label text="Doc Fatt" />
                    <t:template>
                        <Link
                            text="{fattureModel>vbeln}"
                            press=".onNavToDocumentoVendita"
                        />
                    </t:template>
                </t:Column>

                <t:Column
                    id="colBelnr"
                    width="8rem"
                    sortProperty="belnr"
                    filterProperty="belnr"
                >
                    <Label text="N° Doc" />
                    <t:template>
                        <Link
                            text="{fattureModel>belnr}"
                            press=".onNavToDocumento"
                        />
                    </t:template>
                </t:Column>

                <t:Column
                    id="colBudat"
                    width="8rem"
                    sortProperty="budat"
                    filterProperty="budat"
                >
                    <Label text="Data Reg" />
                    <t:template>
                        <Text
                            text="{path: 'fattureModel>budat', formatter: '.formatter.formatDate'}"
                        />
                    </t:template>
                </t:Column>

                <t:Column
                    id="colGjahr"
                    width="6rem"
                    sortProperty="gjahr"
                    filterProperty="gjahr"
                >
                    <Label text="Esercizio" />
                    <t:template>
                        <Text text="{fattureModel>gjahr}" />
                    </t:template>
                </t:Column>

                <t:Column
                    id="colWrbtr"
                    width="9rem"
                    sortProperty="wrbtr"
                    filterProperty="wrbtr"
                >
                    <Label text="Tot Fattura" />
                    <t:template>
                        <ObjectNumber
                            number="{fattureModel>wrbtr}"
                            unit="{fattureModel>waers}"
                        />
                    </t:template>
                </t:Column>

                <t:Column
                    id="colCdUnivoco"
                    width="9rem"
                    sortProperty="cd_univoco"
                    filterProperty="cd_univoco"
                >
                    <Label text="CD Univoco" />
                    <t:template>
                        <Text text="{fattureModel>cd_univoco}" />
                    </t:template>
                </t:Column>

                <t:Column
                    id="colPec"
                    width="12rem"
                    sortProperty="PEC"
                    filterProperty="PEC"
                >
                    <Label text="PEC" />
                    <t:template>
                        <Text text="{fattureModel>PEC}" />
                    </t:template>
                </t:Column>

                <t:Column
                    id="colEsito"
                    width="10rem"
                    sortProperty="esito"
                    filterProperty="esito"
                >
                    <Label text="Esito" />
                    <t:template>
                        <ObjectStatus
                            text="{fattureModel>esito}"
                            icon="{path: 'fattureModel>esito', formatter: '.formatter.statusIcon'}"
                            state="{path: 'fattureModel>esito', formatter: '.formatter.statusState'}"
                        />
                    </t:template>
                </t:Column>

                <t:Column
                    id="colMessage"
                    width="14rem"
                    sortProperty="message"
                    filterProperty="message"
                >
                    <Label text="Messaggio" />
                    <t:template>
                        <Text text="{fattureModel>message}" />
                    </t:template>
                </t:Column>

                <t:Column
                    id="colAzioni"
                    width="16rem"
                >
                    <Label text="Azioni" />
                    <t:template>
                        <HBox>
                            <Button
                                icon="sap-icon://show"
                                type="Transparent"
                                press=".onViewXML"
                            />

                            <Button
                                text="Visualizza Fattura"
                                type="Transparent"
                                press=".onShowAdvancedPDFDialog"
                            />

                            <Button
                                icon="sap-icon://process"
                                tooltip="Ricevi Esito"
                                type="Accept"
                                press=".onButtonRiceviEsitoPress"
                            />
                        </HBox>
                    </t:template>
                </t:Column>
            </t:columns>
        </t:Table>

        <footer>
            <OverflowToolbar>
                <ToolbarSpacer />
                <Button
                    id="btnInviaIntermediario"
                    type="Accept"
                    enabled="false"
                    icon="sap-icon://paper-plane"
                    text="Invia al intermediario"
                    press=".onInvioData"
                />
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>
